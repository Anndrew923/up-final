# Production build flags (no secrets). Merged with `.env` when running `vite build`.
# WHY: `vite build` uses mode `production`; without these lines a machine may ship
# client-side Firestore setDoc for ladder (blocked by P2 rules) even when `.env` is incomplete.
VITE_FIREBASE_USE_EMULATORS=false
VITE_FIREBASE_STORAGE_BUCKET=fitness-app-69f08.firebasestorage.app
VITE_LADDER_CALLABLE_WRITES=true
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
VITE_APP_CHECK_SITE_KEY=6LeedlstAAAAAPwha2IAkXokVHx2lZRl9NkOA2kn
