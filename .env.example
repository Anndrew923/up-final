# Firebase Web SDK (Firebase Console → Project settings → Your apps → Config)
# Copy to .env for local dev. On Netlify, set the same keys in Site → Environment variables.
# Values are not secret for a public web app; rules + backend enforce access.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
