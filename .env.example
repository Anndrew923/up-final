# Firebase web client (public config — still keep out of git if you rotate keys often)
# All four required for real Firestore; see docs/FIREBASE_LEADERBOARD_SETUP.md
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Ladder avatar uploads (Console → Storage bucket name, e.g. your-project.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=

# Local Firebase Emulator Suite (see docs/FIREBASE_EMULATOR.md)
VITE_FIREBASE_USE_EMULATORS=false

# Production build (`npm run build`) also reads `.env.production` — keep Callable writes true there.

# =========================================================================
# MONETIZATION & MOBILE REGISTRATION (REVENUECAT & CAPACITOR)
# =========================================================================
# RevenueCat — public SDK keys; real Play Billing runs on Android/iOS native only.
# Web dev without keys uses local Pro simulation via subscriptionService.
VITE_RC_API_KEY_IOS=
VITE_RC_API_KEY_ANDROID=
VITE_RC_API_KEY_WEB=
VITE_RC_ENTITLEMENT_ID=pro
VITE_RC_PACKAGE_ID=$rc_monthly

# P2 ladder Cloud Function writes — requires deployed functions + Firestore rules.
# Use true on device/internal-test builds against fitness-app-69f08; false for local-only web.
VITE_LADDER_CALLABLE_WRITES=true
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# DYNO INTEL dev/beta Pro bypass (client — auto-on in `npm run dev`)
# Staging production builds only: VITE_DYNO_INTEL_BETA_FREE=true
# Callable parity (Firebase Functions env): DYNO_INTEL_DEV_BYPASS=true | DYNO_INTEL_BETA_FREE=true
# GEMINI_API_KEY belongs in functions/.env.local — NOT in this root .env (see functions/.env.example)
# One-click local stack: npm run dev:dyno (auto-migrates root GEMINI → functions/.env.local once)
# VITE_DYNO_INTEL_BETA_FREE=
