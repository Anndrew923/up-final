// Firestore Security Rules (V2，含通知系統權限修復)
// 已合併 UP Final：leaderboards/{metric}/entries/{uid}、users/{uid}/artifacts/*、users/{uid}/profile/*、users/{uid}/history/*
// 手動部署：firebase deploy --only firestore:rules（見 docs/FIREBASE_LEADERBOARD_SETUP.md）
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function onlyMutate(keys) {
      // 僅允許改動指定欄位（適用 update）
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }
    function isAdmin() {
      // 檢查用戶是否為管理員
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    function hasValidPro(uid) {
      let userData = get(/databases/$(database)/documents/users/$(uid)).data;
      return isOwner(uid)
        && (
          ('purchaseStatus' in userData && userData.purchaseStatus == 'owned') ||
          !('purchaseStatus' in userData)
        )
        && 'subscriptionStatus' in userData
        && userData.subscriptionStatus in ['pro', 'grace']
        && 'proExpiresAtMs' in userData
        && userData.proExpiresAtMs is int
        && userData.proExpiresAtMs >= request.time.toMillis();
    }
    // Billing/verification state is server-authoritative. Public ladder identity
    // lives in leaderboard summary docs, so user documents are private.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if false;

      // ✅ 新增：允許管理員更新認證相關字段
      allow update: if isAdmin()
        && onlyMutate([
          'isVerified',
          'verifiedLadderScore',
          'verificationStatus',
          'verifiedAt',
          'verificationExpiredAt',
          'lastVerificationRejectionAt',
          'verificationRequestId',
          'updatedAt'
        ])
        && request.resource.data.userId == resource.data.userId; // 確保不能修改 userId

      // UP Final：雲端備份 users/{uid}/artifacts/{artifactId}（例如 up_cloud_sync_v1）
      match /artifacts/{artifactId} {
        allow read, write: if hasValidPro(userId);
      }

      // UP Final：Pro 結構化同步（單一 baseline + 每筆歷史獨立文件，避免單一 JSON 1MB 上限）
      match /profile/{docId} {
        allow read, write: if hasValidPro(userId);
      }
      match /history/{recordId} {
        allow read, write: if hasValidPro(userId);
      }
    }

    // Retired social collections are server-only until a Callable contract ships.
    match /friendInvitations/{inviteId} {
      allow read, write: if false;
    }

    match /communityPosts/{postId} {
      allow read, write: if false;
    }

    match /assessments/{assessmentId} {
      allow read, write: if false;
    }

    match /ladderRankings/{rankingId} {
      allow read, write: if false;
    }

    // leaderboards：leaderboards/{metric}/entries/{uid}
    // P2: client writes denied — use Callable `ladderSubmitShard` / `ladderSyncBatch` (Admin SDK).
    match /leaderboards/{metric}/entries/{uid} {
      allow read: if signedIn() && hasValidPro(request.auth.uid);
      allow create, update, delete: if false;
    }

    // leaderboard_previews/{uid} — P2: writes via Callable `ladderSyncPreview` / batch preview only.
    match /leaderboard_previews/{uid} {
      allow read: if signedIn() && hasValidPro(request.auth.uid);
      allow create, update, delete: if false;
    }

    // Server-side ladder quotas (per-shard hourly + full-sync daily); Admin SDK only.
    match /ladder_rate_limits/{uid} {
      allow read, write: if false;
    }

    // DYNO INTEL — Gemini response cache; Admin SDK only (24h TTL).
    match /dyno_intel_cache/{hash} {
      allow read, write: if false;
    }

    // DYNO INTEL — daily quota counters; doc id is uid (dayKey lives inside the doc).
    match /dyno_intel_rate_limits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Ladder UGC reports — Callable `ladderReportUser` only (Admin SDK writes).
    match /ladder_reports/{reportId} {
      allow read, write: if false;
    }

    match /history/{historyId} {
      allow read, write: if false;
    }

    match /userSettings/{settingId} {
      allow read, write: if false;
    }

    // systemConfig：僅讀（無人可寫）
    match /systemConfig/{configId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /verificationRequests/{requestId} {
      allow read, write: if false;
    }

    // ✅ 新增：adminActions 集合
    // 僅管理員可讀寫
    match /adminActions/{actionId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.timestamp is string;

      allow update, delete: if false; // 不允許修改或刪除記錄
    }

    // Global sequence is server-authoritative to prevent collisions and tampering.
    match /verificationSequences/{dateStr} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read, write: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if false;
    }
  }
}
