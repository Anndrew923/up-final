# Cloud Functions local secrets (copy to `.env.local` — never commit)
#
# WHY: DYNO INTEL Callable runs Gemini server-side; the emulator loads this file
# when started via `npm run dev:dyno` from the repo root.
#
# Production deploy also reads `functions/.env` (dotenv) for non-secret flags such as
# LEADERBOARD_PAYWALL_ENABLED — see Firebase Functions dotenv docs.

# Grants Pro + Core entitlement inside dynoIntelChat without Firestore / RC docs.
DYNO_INTEL_DEV_BYPASS=true

# Google AI Studio key — required for Gemini inference (https://aistudio.google.com/apikey)
# WHY: Callable reads this file only — root `.env` VITE_* vars do NOT reach Functions.
# dev:dyno auto-migrates a root GEMINI_API_KEY once if you pasted it in the wrong file.
GEMINI_API_KEY=

# Optional model overrides (defaults in functions/shared/constants.js)
# GEMINI_MODEL_LITE_ID=gemini-2.5-flash-lite
# GEMINI_MODEL_METHODOLOGY_ID=gemini-2.5-flash

# Ladder upload Pro gate (assertLadderUploadAllowed). Default when unset: true (safe).
# Genesis open access: keep false in `.env` and `.env.<projectId>` so Free signed-in users can upload.
# Must stay aligned with src/config/monetization.ts → leaderboardPaywallEnabled.
# LEADERBOARD_PAYWALL_ENABLED=false
